{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rig/schemas/inventory_snapshot.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase",
    "captured_at_mono_ns",
    "captured_at_wall",
    "s3_bucket",
    "ec2_instances",
    "s3_object_versions",
    "ec2_request_ids",
    "s3_request_ids"
  ],
  "properties": {
    "schema_version":      { "type": "integer", "const": 1 },
    "phase": {
      "type": "string",
      "enum": ["inventory_pre", "inventory_post", "inventory_delayed"]
    },
    "captured_at_mono_ns": { "type": "integer", "minimum": 0 },
    "captured_at_wall":    { "type": "string",  "minLength": 1 },
    "s3_bucket":           { "type": "string",  "minLength": 1 },
    "ec2_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["instance_id", "state", "instance_type", "launch_time", "tags"],
        "properties": {
          "instance_id":   { "type": "string" },
          "state":         { "type": "string" },
          "instance_type": { "type": "string" },
          "launch_time":   { "type": "string" },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["Key", "Value"],
              "properties": {
                "Key":   { "type": "string" },
                "Value": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "s3_object_versions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "version_id", "size", "last_modified", "is_delete_marker"],
        "properties": {
          "key":              { "type": "string" },
          "version_id":       { "type": "string" },
          "size":             { "type": "integer", "minimum": 0 },
          "last_modified":    { "type": "string" },
          "is_delete_marker": { "type": "boolean" }
        }
      }
    },
    "ec2_request_ids": { "type": "array", "items": { "type": "string" } },
    "s3_request_ids":  { "type": "array", "items": { "type": "string" } }
  }
}