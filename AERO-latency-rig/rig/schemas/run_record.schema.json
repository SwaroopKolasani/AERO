{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rig/schemas/run_record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_identity",
    "outcome_code",
    "wallclock_sha256",
    "raw_artifacts",
    "completion_proof_sha256",
    "outputs_audit_sha256",
    "classifier_reason"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_identity": {
      "type": "object",
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "type": "integer" }
      }
    },
    "outcome_code": {
      "type": "string",
      "enum": [
        "success",
        "fail_fixture",
        "fail_timeout",
        "fail_cli_nonzero",
        "fail_invalid_session_context",
        "fail_missing_wal",
        "fail_orphan_suspected",
        "fail_audit",
        "fail_completion_proof",
        "fail_rig_error",
        "fail_unknown"
      ]
    },
    "wallclock_sha256":        { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "raw_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout_sha256", "stderr_sha256", "wal_raw_sha256"],
      "properties": {
        "stdout_sha256":  { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "stderr_sha256":  { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "wal_raw_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "completion_proof_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "outputs_audit_sha256":    { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "classifier_reason":       { "type": "string" }
  }
}