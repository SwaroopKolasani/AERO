# AeroCache HTTP
AERO_HTTP_ADDR=:8080
AERO_DEBUG=1

# Upstream OpenAI-compatible backend
AERO_UPSTREAM_URL=http://localhost:11434

# Active model fingerprint
AERO_FINGERPRINT_MODEL=llama3.2:3b
AERO_FINGERPRINT_ENGINE=ollama@local
AERO_FINGERPRINT_DTYPE=cpu

# Determinism/cache gate
AERO_GATE_MODE=strict
AERO_EPOCH=0

# Real tokenizer/template path
AERO_TOKENIZER_DIR=./model-tokenizer
AERO_CHAT_TEMPLATE_KIND=llama3
AERO_CHAT_TEMPLATE_DATE=04 Jul 2026

# Dev-only fallback. Do not use for correctness claims.
# AERO_ALLOW_BYTE_TOKENIZER=1

# L1 in-process cache is always enabled.

# L2 Valkey
AERO_L2_ADDR=127.0.0.1:6379

# L3 Cloudflare R2. Disabled by default.
AERO_L3_ENABLED=0
AERO_R2_ENDPOINT="https://ebc1b017834d547d4ac036dcf5e06b5b.r2.cloudflarestorage.com" \
AERO_R2_BUCKET="aero" \
AERO_R2_ACCESS_KEY_ID="55600cbcbfd37ba86ba0b9463e3a7ead" \
AERO_R2_SECRET_ACCESS_KEY="3a5cbf34a389961716c64d1d507947108f6583aa32bd5704ab7985e95aaa510c" \
AERO_R2_REGION=auto
AERO_R2_PREFIX=aerocache/l3
AERO_L3_TIMEOUT=750ms
AERO_L3_MIN_BYTES=0

# SPA
AERO_SPA_PATH=web/dist